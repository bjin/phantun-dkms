CompileFlags:
  Compiler: clang
  Remove:
    - -mpreferred-stack-boundary=*
    - -mindirect-branch=*
    - -mindirect-branch-register
    - -fmin-function-alignment=*
    - -fconserve-stack
    - -mrecord-mcount
    - -fno-allow-store-data-races
    - -fzero-init-padding-bits=all

Diagnostics:
  Suppress:
    - bugprone-sizeof-expression
