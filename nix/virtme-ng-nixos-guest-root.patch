+NEWROOT=/newroot
+
+# A NixOS host exports a read-only root without /lib, which later breaks
+# kernel module setup (/lib/modules) and similar FHS expectations. Wrap
+# the root in a tmpfs-backed writable overlay so the guest can create
+# whatever directories it needs; all writes stay in guest RAM.
+if ! [ -d /newroot/lib ]; then
+  log 'root lacks /lib -- wrapping it in a writable overlay'
+  mkdir -p /overlay /overlayroot
+  if /bin/mount -n -t tmpfs -o mode=0755 tmpfs /overlay &&
+     mkdir -p /overlay/upper /overlay/work &&
+     /bin/mount -n -t overlay -o lowerdir=/newroot,upperdir=/overlay/upper,workdir=/overlay/work overlay /overlayroot; then
+    NEWROOT=/overlayroot
+  else
+    log 'overlay wrap failed -- continuing with read-only root'
+  fi
+fi
+
 # Can we actually use /newroot/ as root?
-if ! mount -t proc -o nosuid,noexec,nodev proc /newroot/proc 2>/dev/null; then
+if ! mount -t proc -o nosuid,noexec,nodev proc "$NEWROOT"/proc 2>/dev/null; then
   # QEMU 1.5 and below have a bug in virtfs that prevents mounting
   # anything on top of a virtfs mount.
   log "your host's virtfs is broken -- using a fallback tmpfs"
   need_fallback_tmpfs=1
 else
-  umount /newroot/proc  # Don't leave garbage behind
+  umount "$NEWROOT"/proc  # Don't leave garbage behind
 fi
 
