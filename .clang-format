# Linux-kernel-style clang-format for C kernel modules
# Based on the upstream Linux kernel .clang-format, trimmed for C-only projects.
# Intended for clang-format >= 11.

---
Language: C
BasedOnStyle: LLVM

UseTab: Always
IndentWidth: 8
TabWidth: 8
ContinuationIndentWidth: 8

ColumnLimit: 120

BreakBeforeBraces: Linux
IndentCaseLabels: false

PointerAlignment: Right
DerivePointerAlignment: false

AlignAfterOpenBracket: Align
AlignOperands: true
AlignEscapedNewlines: Left
AlignTrailingComments: false

AllowShortBlocksOnASingleLine: Never
AllowShortCaseLabelsOnASingleLine: false
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

BinPackArguments: true
BinPackParameters: true

KeepEmptyLinesAtTheStartOfBlocks: false
MaxEmptyLinesToKeep: 1

SortIncludes: Never
IncludeBlocks: Preserve

SpaceBeforeParens: ControlStatements
SpacesInParentheses: false
SpacesInSquareBrackets: false
SpaceInEmptyParentheses: false
SpaceBeforeAssignmentOperators: true

IndentGotoLabels: false

# Helps with common kernel-style statement-like macros.
StatementMacros:
  - list_for_each
  - list_for_each_entry
  - list_for_each_entry_safe
  - hlist_for_each_entry
  - hlist_for_each_entry_safe
  - for_each_set_bit
  - for_each_clear_bit
  - xa_for_each
  - idr_for_each_entry
